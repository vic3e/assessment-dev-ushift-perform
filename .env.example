# -------------------------------------------------------
# Node.js Configuration
# -------------------------------------------------------
# Suppress Node.js deprecation warnings in production
NODE_NO_WARNINGS=1

# -------------------------------------------------------
# Mailgun – Email delivery
# -------------------------------------------------------
# Your Mailgun API key (found in Mailgun dashboard → API Keys)
MAILGUN_API_KEY=key-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Your verified Mailgun sending domain (e.g. mg.yourdomain.com)
MAILGUN_DOMAIN=mg.yourdomain.com

# The "From" address used in outgoing emails.
# IMPORTANT: this must use your verified Mailgun sending domain (e.g. noreply@mg.yourdomain.com)
# Using a different domain will cause a Mailgun 400 "not a valid address" error.
FROM_EMAIL=noreply@mg.yourdomain.com

# Admin / internal email that receives a copy of every submission
ADMIN_EMAIL=admin@yourdomain.com

# -------------------------------------------------------
# App config
# -------------------------------------------------------
# Displayed in email subjects and footers (optional – defaults to "Coaching Completion Assessment")
NEXT_PUBLIC_APP_NAME=Coaching Completion Assessment